@article{jacobson_comparative_2008,
  title = {Comparative {{Patterns}} of {{Interracial Marriage}}: {{Structural Opportunities}}, {{Third-party Factors}}, and {{Temporal Change}} in {{Immigrant Societies}}},
  shorttitle = {Comparative {{Patterns}} of {{Interracial Marriage}}},
  author = {Jacobson, Cardell K. and Heaton, Tim B.},
  date = {2008},
  journaltitle = {Journal of Comparative Family Studies},
  volume = {39},
  number = {2},
  eprint = {41604207},
  eprinttype = {jstor},
  pages = {129--148},
  issn = {0047-2328},
  url = {http://www.jstor.org/stable/41604207},
  abstract = {Using census data, we compare patterns of interracial marriage in six different contexts where immigration has played a central role in population composition. We use Kalmijn's (1998) general theoretical perspective that emphasizes how opportunity structures and third-party factors affect inter-group marriage rates. More specifically, we hypothesize that rates of intermarriage are influenced by: (1) structural opportunities as reflected by the history of inequality, segregation, and racial oppression, (2) third-party interests such as cultural and linguistic differences, and (3) societal trends that reflect choices in the formation of intimate relationships and racial equality. We use age as a surrogate for the trends over time. We first estimate log-linear models to gauge the extent of overall homogamy and race specific homogamy in each cultural setting. We then use multinomial logistic regression to evaluate age differences. Cross-cultural differences in rates of intermarriage are substantial. Intermarriage is more common in societies where structural opportunities for contact are high and third-party interests low (Hawaii and New Zealand), almost non-existent among some groups in societies where the strong inter-group tensions remain, (Xinjiang Province, China and South Africa), and intermediate in societies with moderate degrees of opportunities and third-party interests (United States and Canada). Age is generally negatively associated with intermarriage, with some interesting exceptions. Interracial marriage in general is becoming more common in the arenas we examine. A partir de données de recensement, nous comparons des modèles de mariages interraciaux dans six différents contextes où l'immigration a joué un rôle central dans la composition de la population. Nous nous servons de la perspective théorique générale de Kalmijn (1998) qui souligne comment les structures occasionnelles et les facteurs de tiers affectent le taux des mariages entre groupes. Plus spécifiquement, nous formulons l'hypothèse que les taux d'intermariages sont influencés par: 1) les structures occasionnelles qui se manifestent dans l'histoire de l'inégalité, de la ségrégation et de l'oppression raciale; 2) les intérêts de tiers telles que les différences culturelles et linguistiques; et 3) les tendances sociétales qui reflètent des choix dans la formation de relations intimes et d'égalité raciale. Nous utilisons l'âge comme un élément représentatif de ces tendances dans le temps. Nous considérons d'abord des modèles log-linéaires pour mesurer l'étendue de l'homogamie en général et de l'homogamie de race spécifique dans chaque cadre culturel. Nous utilisons ensuite la régression logistique multinomiale pour évaluer les différences d'âge. Les différences cross-culturelles dans les taux d'intermariages sont substantielles. Les intermariages sont plus communs dans les sociétés où les occasions structurales de contact sont élevées et les intérêts de tiers bas (Hawaii et Nouvelle-Zélande), quasi inexistants dans quelques groupes appartenant à des sociétés où se manisfestent de fortes tensions entre groupes (Province de Xinjiang, Chine et Afrique du Sud) et de fréquence moyenne dans des sociétés où les occasions de contact et les intérêts de tiers sont modérés (Etats-Unis et Canada). L'âge est généralement associé négativement à l'intermariage, avec quelques exceptions intéressantes. En général, le mariage interracial devient plus commun dans les contextes que nous examinons. Mediante el uso de datos censales, comparamos modelos de matrimonios interraciales en seis contextos en que la inmigración ha tenido un papel central en la composición de la población. Usamos la perspectiva teorética general de Kalmijn (1998) que enfatiza la forma en que la estructura de oportunidades y los factores de terceras personas afectan la tasa de matrimonios intergrupales. Más específicamente, hacemos la hipótesis que la tasa de matrimonios intergrupales está influida por: (1) las oportunidades estructurales que se ven reflejadas en la historia de la inigualdad, segregación y opresión racial, (2) otros intereses como lo son las diferencias linguísticas y culturales, y (3) las corrientes sociales que reflejan preferencias en la formación de relaciones íntimas y en la igualdad racial. Usamos la edad como un substituto por las tendencias manifestadas a través del tiempo. Primero utilizamos modelos logolineales para calcular la tasa de homogamia general y la de homogamia racial específica de cada medio cultural. Después usamos regresión logística multinomial para evaluar la diferencia de edades. Las diferencias crosculturales en las tasas de matrimonios intergrupales son sustanciales. El matrimonio intergrupal es más común en las sociedades en los que las oportunidades estructurales para el contacto son altas y en la que otros intereses son bajos (como en Hawai y en Nueva Zelanda); es casi inexistente entre algunos grupos en sociedades en que existen fuertes tensiones intergrupales (Provincia de Xinjiang, China y Sudáfrica) y es intermedio en sociedades con grados moderados de oportunidades y otros intereses (Estados Unidos y Canadá). La edad, con algunas excepciones interesantes, tiene generalmente asociaciones negativas con el matrimonio intergrupal. El matrimonio interracial en general se está haciendo más común en las\_zonas examinadas.},
  keywords = {cross-national,intermarriage,trends},
  file = {/Users/aarong/Zotero/storage/37HQT35R/Jacobson and Heaton - 2008 - Comparative Patterns of Interracial Marriage Stru.pdf}
}

