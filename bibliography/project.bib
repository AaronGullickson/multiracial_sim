@article{jacobson_comparative_2008,
  title = {Comparative {{Patterns}} of {{Interracial Marriage}}: {{Structural Opportunities}}, {{Third-party Factors}}, and {{Temporal Change}} in {{Immigrant Societies}}},
  shorttitle = {Comparative {{Patterns}} of {{Interracial Marriage}}},
  author = {Jacobson, Cardell K. and Heaton, Tim B.},
  year = {2008},
  journal = {Journal of Comparative Family Studies},
  volume = {39},
  number = {2},
  eprint = {41604207},
  eprinttype = {jstor},
  pages = {129--148},
  issn = {0047-2328},
  abstract = {Using census data, we compare patterns of interracial marriage in six different contexts where immigration has played a central role in population composition. We use Kalmijn's (1998) general theoretical perspective that emphasizes how opportunity structures and third-party factors affect inter-group marriage rates. More specifically, we hypothesize that rates of intermarriage are influenced by: (1) structural opportunities as reflected by the history of inequality, segregation, and racial oppression, (2) third-party interests such as cultural and linguistic differences, and (3) societal trends that reflect choices in the formation of intimate relationships and racial equality. We use age as a surrogate for the trends over time. We first estimate log-linear models to gauge the extent of overall homogamy and race specific homogamy in each cultural setting. We then use multinomial logistic regression to evaluate age differences. Cross-cultural differences in rates of intermarriage are substantial. Intermarriage is more common in societies where structural opportunities for contact are high and third-party interests low (Hawaii and New Zealand), almost non-existent among some groups in societies where the strong inter-group tensions remain, (Xinjiang Province, China and South Africa), and intermediate in societies with moderate degrees of opportunities and third-party interests (United States and Canada). Age is generally negatively associated with intermarriage, with some interesting exceptions. Interracial marriage in general is becoming more common in the arenas we examine. A partir de donn{\'e}es de recensement, nous comparons des mod{\`e}les de mariages interraciaux dans six diff{\'e}rents contextes o{\`u} l'immigration a jou{\'e} un r{\^o}le central dans la composition de la population. Nous nous servons de la perspective th{\'e}orique g{\'e}n{\'e}rale de Kalmijn (1998) qui souligne comment les structures occasionnelles et les facteurs de tiers affectent le taux des mariages entre groupes. Plus sp{\'e}cifiquement, nous formulons l'hypoth{\`e}se que les taux d'intermariages sont influenc{\'e}s par: 1) les structures occasionnelles qui se manifestent dans l'histoire de l'in{\'e}galit{\'e}, de la s{\'e}gr{\'e}gation et de l'oppression raciale; 2) les int{\'e}r{\^e}ts de tiers telles que les diff{\'e}rences culturelles et linguistiques; et 3) les tendances soci{\'e}tales qui refl{\`e}tent des choix dans la formation de relations intimes et d'{\'e}galit{\'e} raciale. Nous utilisons l'{\^a}ge comme un {\'e}l{\'e}ment repr{\'e}sentatif de ces tendances dans le temps. Nous consid{\'e}rons d'abord des mod{\`e}les log-lin{\'e}aires pour mesurer l'{\'e}tendue de l'homogamie en g{\'e}n{\'e}ral et de l'homogamie de race sp{\'e}cifique dans chaque cadre culturel. Nous utilisons ensuite la r{\'e}gression logistique multinomiale pour {\'e}valuer les diff{\'e}rences d'{\^a}ge. Les diff{\'e}rences cross-culturelles dans les taux d'intermariages sont substantielles. Les intermariages sont plus communs dans les soci{\'e}t{\'e}s o{\`u} les occasions structurales de contact sont {\'e}lev{\'e}es et les int{\'e}r{\^e}ts de tiers bas (Hawaii et Nouvelle-Z{\'e}lande), quasi inexistants dans quelques groupes appartenant {\`a} des soci{\'e}t{\'e}s o{\`u} se manisfestent de fortes tensions entre groupes (Province de Xinjiang, Chine et Afrique du Sud) et de fr{\'e}quence moyenne dans des soci{\'e}t{\'e}s o{\`u} les occasions de contact et les int{\'e}r{\^e}ts de tiers sont mod{\'e}r{\'e}s (Etats-Unis et Canada). L'{\^a}ge est g{\'e}n{\'e}ralement associ{\'e} n{\'e}gativement {\`a} l'intermariage, avec quelques exceptions int{\'e}ressantes. En g{\'e}n{\'e}ral, le mariage interracial devient plus commun dans les contextes que nous examinons. Mediante el uso de datos censales, comparamos modelos de matrimonios interraciales en seis contextos en que la inmigraci{\'o}n ha tenido un papel central en la composici{\'o}n de la poblaci{\'o}n. Usamos la perspectiva teor{\'e}tica general de Kalmijn (1998) que enfatiza la forma en que la estructura de oportunidades y los factores de terceras personas afectan la tasa de matrimonios intergrupales. M{\'a}s espec{\'i}ficamente, hacemos la hip{\'o}tesis que la tasa de matrimonios intergrupales est{\'a} influida por: (1) las oportunidades estructurales que se ven reflejadas en la historia de la inigualdad, segregaci{\'o}n y opresi{\'o}n racial, (2) otros intereses como lo son las diferencias lingu{\'i}sticas y culturales, y (3) las corrientes sociales que reflejan preferencias en la formaci{\'o}n de relaciones {\'i}ntimas y en la igualdad racial. Usamos la edad como un substituto por las tendencias manifestadas a trav{\'e}s del tiempo. Primero utilizamos modelos logolineales para calcular la tasa de homogamia general y la de homogamia racial espec{\'i}fica de cada medio cultural. Despu{\'e}s usamos regresi{\'o}n log{\'i}stica multinomial para evaluar la diferencia de edades. Las diferencias crosculturales en las tasas de matrimonios intergrupales son sustanciales. El matrimonio intergrupal es m{\'a}s com{\'u}n en las sociedades en los que las oportunidades estructurales para el contacto son altas y en la que otros intereses son bajos (como en Hawai y en Nueva Zelanda); es casi inexistente entre algunos grupos en sociedades en que existen fuertes tensiones intergrupales (Provincia de Xinjiang, China y Sud{\'a}frica) y es intermedio en sociedades con grados moderados de oportunidades y otros intereses (Estados Unidos y Canad{\'a}). La edad, con algunas excepciones interesantes, tiene generalmente asociaciones negativas con el matrimonio intergrupal. El matrimonio interracial en general se est{\'a} haciendo m{\'a}s com{\'u}n en las\_zonas examinadas.},
  keywords = {cross-national,intermarriage,trends},
  file = {/Users/aarong/Zotero/storage/37HQT35R/Jacobson and Heaton - 2008 - Comparative Patterns of Interracial Marriage Stru.pdf}
}

