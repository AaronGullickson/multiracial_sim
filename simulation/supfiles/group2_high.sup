***************************************************************************
* Supervisory file for SOCSIM microsimulation for 2 Group test with high
* exogamy
***************************************************************************

segments 20
input_file presim

marriage_queues 1

***************************************************************************

* increment 5 years for 20 segments and decrease endogamy each time
duration 60
include basic_rates
endogamy 0.98
run

duration 60
include basic_rates
endogamy 0.97
run

duration 60
include basic_rates
endogamy 0.96
run

duration 60
include basic_rates
endogamy 0.95
