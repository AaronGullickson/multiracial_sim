duration 60
include basic_rates
endogamy 0.92
run

duration 60
include basic_rates
endogamy 0.91
run

duration 60
include basic_rates
endogamy 0.90
run

duration 60
include basic_rates
endogamy 0.89
run

duration 60
include basic_rates
endogamy 0.88
run

duration 60
include basic_rates
endogamy 0.87
run

duration 60
include basic_rates
endogamy 0.86
run

duration 60
